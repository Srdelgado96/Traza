@using Traza.Web.Components.Models
@inject DialogService DialogService

<RadzenTemplateForm Data="@Modelo" Submit="@OnSubmit">
    <div class="p-3">
        <div class="mb-3">
            <label class="form-label">@EtiquetaNombre</label>
            <RadzenTextBox @bind-Value="Modelo.Nombre" Name="Nombre" Style="width:100%;" />
            <RadzenRequiredValidator Component="Nombre" Text="El nombre es obligatorio." Popup="false" />
        </div>

        @if (MostrarDescripcion)
        {
            <div class="mb-3">
                <label class="form-label">Descripcion</label>
                <RadzenTextArea @bind-Value="Modelo.Descripcion" Rows="3" Style="width:100%;" />
            </div>
        }

        @if (MostrarOrden)
        {
            <div class="mb-3">
                <label class="form-label">Orden</label>
                <RadzenNumeric @bind-Value="Modelo.Orden" Name="Orden" Min="1" Style="width:100%;" />
                <RadzenRequiredValidator Component="Orden" Text="El orden es obligatorio." Popup="false" />
            </div>
        }

        @if (MostrarEsCierre)
        {
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="esCierreDialog" @bind="Modelo.EsCierre" />
                <label class="form-check-label" for="esCierreDialog">Es estado de cierre</label>
            </div>
        }

        @if (MostrarActivo)
        {
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="activoDialog" @bind="Modelo.Activo" />
                <label class="form-check-label" for="activoDialog">Activo</label>
            </div>
        }

        <div class="d-flex justify-content-end gap-2">
            <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@Cancelar" />
            <RadzenButton Text="Guardar" Icon="save" ButtonType="ButtonType.Submit" />
        </div>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter]
    public CatalogoSimpleFormModel Modelo { get; set; } = new();

    [Parameter]
    public string EtiquetaNombre { get; set; } = "Nombre";

    [Parameter]
    public bool MostrarOrden { get; set; }

    [Parameter]
    public bool MostrarEsCierre { get; set; }

    [Parameter]
    public bool MostrarDescripcion { get; set; }

    [Parameter]
    public bool MostrarActivo { get; set; }

    private EventCallback<CatalogoSimpleFormModel> OnSubmit
        => EventCallback.Factory.Create<CatalogoSimpleFormModel>(this, Guardar);

    private void Guardar(CatalogoSimpleFormModel _)
    {
        DialogService.Close(Modelo);
    }

    private void Cancelar()
    {
        DialogService.Close(null);
    }
}
