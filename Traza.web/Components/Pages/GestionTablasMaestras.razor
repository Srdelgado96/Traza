    private RenderFragment RenderActionsColumn<TItem>(
        RadzenDataGrid<TItem>? grid,
        string title,
        Func<TItem, Task> onEdit,
        Func<TItem, Task> onSave,
        Func<TItem, Task> onCancel,
        Func<TItem, Task> onDelete) where TItem : class
        => @<RadzenDataGridColumn TItem="TItem" Title="@title" Width="150px" TextAlign="TextAlign.Center">
            <Template Context="item">
                <button type="button" class="btn traza-icon-btn" @onclick="() => onEdit(item)" title="Editar">
                    <i class="fi fi-rr-pencil"></i>
                </button>
                <button type="button" class="btn traza-icon-btn traza-icon-btn-danger" @onclick="() => onDelete(item)" title="Eliminar">
                    <i class="fi fi-rr-trash"></i>
                </button>
            </Template>
            <EditTemplate Context="item">
                <button type="button" class="btn traza-icon-btn traza-icon-btn-success" @onclick="() => onSave(item)" title="Guardar">
                    <i class="fi fi-rr-check"></i>
                </button>
                <button type="button" class="btn traza-icon-btn" @onclick="() => onCancel(item)" title="Cancelar">
                    <i class="fi fi-rr-cross-small"></i>
                </button>
            </EditTemplate>
        </RadzenDataGridColumn>;

    private async Task EditarFilaAsync<TItem>(RadzenDataGrid<TItem>? grid, TItem item) where TItem : class
    {
        if (grid is null)
        {
            return;
        }

        await grid.EditRow(item);
    }

    private async Task CancelarEdicionAsync<TItem>(RadzenDataGrid<TItem>? grid, TItem item) where TItem : class
    {
        if (grid is not null)
        {
            grid.CancelEditRow(item);
        }

        await RecargarTodoAsync();
    }

    private async Task GuardarFilaAsync<TItem>(RadzenDataGrid<TItem>? grid, TItem item) where TItem : class
    {
        if (!ValidarEntidad(item))
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        var entidad = await db.Set<TItem>().FindAsync(GetId(item));
        if (entidad is null)
        {
            MostrarAviso("No se ha encontrado el registro.");
            return;
        }

        CopiarValores(item, entidad);
        await GuardarCambiosAsync(db, "Registro actualizado.");

        if (grid is not null)
        {
            await grid.UpdateRow(item);
        }

        await RecargarTodoAsync();
    }

