                        <RadzenDataGrid @ref="gridPrioridadesProyecto" Data="@prioridadesProyecto" TItem="PrioridadProyecto" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay prioridades.">
