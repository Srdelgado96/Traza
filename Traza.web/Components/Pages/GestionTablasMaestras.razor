@code {
    private bool cargando = true;

    private RadzenDataGrid<Departamento>? gridDepartamentos;
    private RadzenDataGrid<Proceso>? gridProcesos;
    private RadzenDataGrid<TipologiaIncidencia>? gridTipologias;
    private RadzenDataGrid<EstadoIncidencia>? gridEstadosIncidencia;
    private RadzenDataGrid<EstadoDetalleIncidencia>? gridEstadosDetalle;
    private RadzenDataGrid<TipoDocumentoReferencia>? gridTiposDocumento;
    private RadzenDataGrid<TipoAdjunto>? gridTiposAdjunto;
    private RadzenDataGrid<TipoCosteNoCalidad>? gridTiposCoste;
    private RadzenDataGrid<OrigenAccionMejora>? gridOrigenesAccion;
    private RadzenDataGrid<TipoAccionMejora>? gridTiposAccion;
    private RadzenDataGrid<EstadoAccionMejora>? gridEstadosAccion;
    private RadzenDataGrid<AreaProyecto>? gridAreasProyecto;
    private RadzenDataGrid<EstadoProyecto>? gridEstadosProyecto;
    private RadzenDataGrid<PrioridadProyecto>? gridPrioridadesProyecto;
    private RadzenDataGrid<EstadoFaseProyecto>? gridEstadosFase;

    private List<Departamento> departamentos = [];
    private List<Proceso> procesos = [];
    private List<TipologiaIncidencia> tipologias = [];
    private List<EstadoIncidencia> estadosIncidencia = [];
    private List<EstadoDetalleIncidencia> estadosDetalleIncidencia = [];
    private List<TipoDocumentoReferencia> tiposDocumento = [];
    private List<TipoAdjunto> tiposAdjunto = [];
    private List<TipoCosteNoCalidad> tiposCosteNoCalidad = [];
    private List<OrigenAccionMejora> origenesAccion = [];
    private List<TipoAccionMejora> tiposAccion = [];
    private List<EstadoAccionMejora> estadosAccionMejora = [];
    private List<AreaProyecto> areasProyecto = [];
    private List<EstadoProyecto> estadosProyecto = [];
    private List<PrioridadProyecto> prioridadesProyecto = [];
    private List<EstadoFaseProyecto> estadosFaseProyecto = [];

    protected override async Task OnInitializedAsync()
    {
        await RecargarTodoAsync();
        cargando = false;
    }

    private async Task RecargarTodoAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();

        departamentos = await db.Departamentos.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        procesos = await db.Procesos.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        tipologias = await db.TipologiasIncidencia.AsNoTracking().Include(x => x.Proceso).OrderBy(x => x.Proceso.Nombre).ThenBy(x => x.Nombre).ToListAsync();
        estadosIncidencia = await db.EstadosIncidencia.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
        estadosDetalleIncidencia = await db.EstadosDetalleIncidencia.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
        tiposDocumento = await db.TiposDocumentoReferencia.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        tiposAdjunto = await db.TiposAdjunto.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        tiposCosteNoCalidad = await db.TiposCosteNoCalidad.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        origenesAccion = await db.OrigenesAccionMejora.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        tiposAccion = await db.TiposAccionMejora.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        estadosAccionMejora = await db.EstadosAccionMejora.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
        areasProyecto = await db.AreasProyecto.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        estadosProyecto = await db.EstadosProyecto.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
        prioridadesProyecto = await db.PrioridadesProyecto.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
        estadosFaseProyecto = await db.EstadosFaseProyecto.AsNoTracking().OrderBy(x => x.Orden).ThenBy(x => x.Nombre).ToListAsync();
    }

