                    <RadzenTabsItem Text="Estados accion">
                        @RenderHeader("Estados de accion", AbrirNuevoEstadoAccionAsync)
                        <RadzenDataGrid @ref="gridEstadosAccion" Data="@estadosAccionMejora" TItem="EstadoAccionMejora" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay estados.">
                            <Columns>
                                <RadzenDataGridColumn TItem="EstadoAccionMejora" Property="Nombre" Title="Nombre">
