                    <RadzenTabsItem Text="Origenes mejora">
                        @RenderHeader("Origenes de mejora", AbrirNuevoOrigenAccionAsync)
                        <RadzenDataGrid @ref="gridOrigenesAccion" Data="@origenesAccion" TItem="OrigenAccionMejora" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay origenes.">
