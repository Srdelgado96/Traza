@page "/gestion-tablas-maestras"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Traza.Web.Components.Dialogs
@using Traza.Web.Components.Models
@using Traza.Web.Data
@using Traza.Web.Data.Entidades
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Gestion de Tablas Maestras | Traza</PageTitle>

@if (cargando)
{
    <div class="card card-round">
        <div class="card-body py-5 text-center">
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
            <div class="mt-3 text-muted">Cargando catalogos...</div>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h4 class="page-title">Gestion de tablas maestras</h4>
            <div class="text-muted">Alta con dialogo, edicion en linea y acciones directas por registro.</div>
        </div>
    </div>

    <div class="card card-round">
        <div class="card-body">
            <div class="traza-master-tabs">
            <RadzenTabs>
                <Tabs>
                    <RadzenTabsItem Text="Departamentos">
                        @RenderHeader("Departamentos", AbrirNuevoDepartamentoAsync)
                        <RadzenDataGrid @ref="gridDepartamentos" Data="@departamentos" TItem="Departamento" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay departamentos.">
                            <Columns>
                                <RadzenDataGridColumn TItem="Departamento" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridDepartamentos, "acciones", (Departamento item) => EditarFilaAsync(gridDepartamentos, item), (Departamento item) => GuardarFilaAsync(gridDepartamentos, item), (Departamento item) => CancelarEdicionAsync(gridDepartamentos, item), (Departamento item) => EliminarEntidadAsync<Departamento>(item.Id, "Eliminar departamento", "Este departamento se eliminara si no esta en uso."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Procesos">
                        @RenderHeader("Procesos", AbrirNuevoProcesoAsync)
                        <RadzenDataGrid @ref="gridProcesos" Data="@procesos" TItem="Proceso" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay procesos.">
                            <Columns>
                                <RadzenDataGridColumn TItem="Proceso" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridProcesos, "acciones", (Proceso item) => EditarFilaAsync(gridProcesos, item), (Proceso item) => GuardarFilaAsync(gridProcesos, item), (Proceso item) => CancelarEdicionAsync(gridProcesos, item), (Proceso item) => EliminarEntidadAsync<Proceso>(item.Id, "Eliminar proceso", "Este proceso se eliminara si no esta relacionado con otros registros."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Tipologias">
                        @RenderHeader("Tipologias", AbrirNuevaTipologiaAsync)
                        <RadzenDataGrid @ref="gridTipologias" Data="@tipologias" TItem="TipologiaIncidencia" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="10" EmptyText="No hay tipologias.">
                            <Columns>
                                <RadzenDataGridColumn TItem="TipologiaIncidencia" Title="Proceso">
                                    <Template Context="item">@item.Proceso.Nombre</Template>
                                    <EditTemplate Context="item">
                                        <RadzenDropDown Data="@procesos" TextProperty="Nombre" ValueProperty="Id" @bind-Value="item.ProcesoId" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="TipologiaIncidencia" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="TipologiaIncidencia" Title="Activa" Width="120px">
                                    <Template Context="item">@(item.Activa ? "Si" : "No")</Template>
                                    <EditTemplate Context="item">
                                        <RadzenCheckBox @bind-Value="item.Activa" TValue="bool" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridTipologias, "acciones", (TipologiaIncidencia item) => EditarFilaAsync(gridTipologias, item), (TipologiaIncidencia item) => GuardarFilaAsync(gridTipologias, item), (TipologiaIncidencia item) => CancelarEdicionAsync(gridTipologias, item), (TipologiaIncidencia item) => EliminarEntidadAsync<TipologiaIncidencia>(item.Id, "Eliminar tipologia", "La tipologia se eliminara si no esta usada por incidencias."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Estados incidencia">
                        @RenderHeader("Estados de incidencia", AbrirNuevoEstadoIncidenciaAsync)
