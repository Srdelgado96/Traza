                                    <EditTemplate Context="item">
                                        <RadzenCheckBox @bind-Value="item.EsCierre" TValue="bool" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridEstadosAccion, "acciones", (EstadoAccionMejora item) => EditarFilaAsync(gridEstadosAccion, item), (EstadoAccionMejora item) => GuardarFilaAsync(gridEstadosAccion, item), (EstadoAccionMejora item) => CancelarEdicionAsync(gridEstadosAccion, item), (EstadoAccionMejora item) => EliminarEntidadAsync<EstadoAccionMejora>(item.Id, "Eliminar estado", "El estado se eliminara si no esta en uso."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Areas proyecto">
                        @RenderHeader("Areas de proyecto", AbrirNuevaAreaProyectoAsync)
                        <RadzenDataGrid @ref="gridAreasProyecto" Data="@areasProyecto" TItem="AreaProyecto" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay areas de proyecto.">
                            <Columns>
                                <RadzenDataGridColumn TItem="AreaProyecto" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridAreasProyecto, "acciones", (AreaProyecto item) => EditarFilaAsync(gridAreasProyecto, item), (AreaProyecto item) => GuardarFilaAsync(gridAreasProyecto, item), (AreaProyecto item) => CancelarEdicionAsync(gridAreasProyecto, item), (AreaProyecto item) => EliminarEntidadAsync<AreaProyecto>(item.Id, "Eliminar area", "El area se eliminara si no esta relacionada con proyectos."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Estados proyecto">
                        @RenderHeader("Estados de proyecto", AbrirNuevoEstadoProyectoAsync)
                        <RadzenDataGrid @ref="gridEstadosProyecto" Data="@estadosProyecto" TItem="EstadoProyecto" EditMode="DataGridEditMode.Single" AllowPaging="true" PageSize="8" EmptyText="No hay estados.">
                            <Columns>
                                <RadzenDataGridColumn TItem="EstadoProyecto" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
