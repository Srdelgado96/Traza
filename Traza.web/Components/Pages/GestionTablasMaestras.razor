                            <Columns>
                                <RadzenDataGridColumn TItem="EstadoIncidencia" Property="Nombre" Title="Nombre">
                                    <EditTemplate Context="item">
                                        <RadzenTextBox @bind-Value="item.Nombre" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="EstadoIncidencia" Property="Orden" Title="Orden" Width="120px">
                                    <EditTemplate Context="item">
                                        <RadzenNumeric @bind-Value="item.Orden" Min="1" Style="width:100%;" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="EstadoIncidencia" Title="Es cierre" Width="130px">
                                    <Template Context="item">@(item.EsCierre ? "Si" : "No")</Template>
                                    <EditTemplate Context="item">
                                        <RadzenCheckBox @bind-Value="item.EsCierre" TValue="bool" />
                                    </EditTemplate>
                                </RadzenDataGridColumn>
                                @RenderActionsColumn(gridEstadosIncidencia, "acciones", (EstadoIncidencia item) => EditarFilaAsync(gridEstadosIncidencia, item), (EstadoIncidencia item) => GuardarFilaAsync(gridEstadosIncidencia, item), (EstadoIncidencia item) => CancelarEdicionAsync(gridEstadosIncidencia, item), (EstadoIncidencia item) => EliminarEntidadAsync<EstadoIncidencia>(item.Id, "Eliminar estado", "El estado se eliminara si no esta en uso."))
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Estados detalle">
                        @RenderHeader("Estados de detalle", AbrirNuevoEstadoDetalleAsync)
