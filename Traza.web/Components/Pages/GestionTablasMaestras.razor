    private async Task AbrirNuevaTipologiaAsync()
    {
        var modelo = new TipologiaFormModel
        {
            ProcesoId = procesos.FirstOrDefault()?.Id,
            Activa = true
        };

        var resultado = await DialogService.OpenAsync<TipologiaDialog>(
            "Nueva tipologia",
            new Dictionary<string, object?>
            {
                [nameof(TipologiaDialog.Modelo)] = modelo,
                [nameof(TipologiaDialog.Procesos)] = procesos
            },
            new DialogOptions { Width = "520px", CloseDialogOnOverlayClick = true });

        if (resultado is not TipologiaFormModel tipologia || !ValidarTipologia(tipologia))
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        db.TipologiasIncidencia.Add(new TipologiaIncidencia
        {
            ProcesoId = tipologia.ProcesoId!.Value,
            Nombre = tipologia.Nombre.Trim(),
            Activa = tipologia.Activa
        });

        await GuardarCambiosAsync(db, "Tipologia creada.");
        await RecargarTodoAsync();
    }

    private async Task AbrirDialogoSimpleYCrearAsync<TItem>(string titulo, bool mostrarOrden = false, bool mostrarEsCierre = false) where TItem : class, new()
    {
        var modelo = new CatalogoSimpleFormModel();
        if (mostrarOrden)
        {
            modelo.Orden = 1;
        }

        var resultado = await DialogService.OpenAsync<CatalogoSimpleDialog>(
            titulo,
            new Dictionary<string, object?>
            {
                [nameof(CatalogoSimpleDialog.Modelo)] = modelo,
                [nameof(CatalogoSimpleDialog.MostrarOrden)] = mostrarOrden,
                [nameof(CatalogoSimpleDialog.MostrarEsCierre)] = mostrarEsCierre
            },
            new DialogOptions { Width = "480px", CloseDialogOnOverlayClick = true });

        if (resultado is not CatalogoSimpleFormModel formulario || !ValidarFormulario(formulario, mostrarOrden))
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        var entidad = new TItem();
        AplicarFormularioSimple(entidad, formulario);
        db.Set<TItem>().Add(entidad);

        await GuardarCambiosAsync(db, "Registro creado.");
        await RecargarTodoAsync();
    }

    private async Task GuardarCambiosAsync(ApplicationDbContext db, string mensajeExito)
    {
        try
        {
            await db.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Guardado", mensajeExito);
        }
        catch (DbUpdateException)
        {
            NotificationService.Notify(NotificationSeverity.Error, "No se pudo guardar", "Revisa si el nombre ya existe o si falta algun dato obligatorio.");
        }
    }

    private async Task EliminarEntidadAsync<T>(int id, string titulo, string mensaje) where T : class
    {
        var confirmacion = await DialogService.Confirm(mensaje, titulo, new ConfirmOptions
        {
            OkButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (confirmacion != true)
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        var entidad = await db.Set<T>().FindAsync(id);
        if (entidad is null)
        {
            return;
        }

        db.Remove(entidad);

        try
        {
            await db.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Eliminado", "Registro eliminado correctamente.");
        }
        catch (DbUpdateException)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No se pudo eliminar", "Este registro esta siendo usado por otros datos y no se puede borrar.");
        }

        await RecargarTodoAsync();
    }

    private bool ValidarFormulario(CatalogoSimpleFormModel formulario, bool requiereOrden)
    {
        if (string.IsNullOrWhiteSpace(formulario.Nombre))
        {
            MostrarAviso("El nombre es obligatorio.");
            return false;
        }

        if (requiereOrden && (!formulario.Orden.HasValue || formulario.Orden <= 0))
        {
            MostrarAviso("El orden debe ser mayor que cero.");
            return false;
        }

        return true;
    }

    private bool ValidarTipologia(TipologiaFormModel formulario)
    {
        if (!formulario.ProcesoId.HasValue)
        {
            MostrarAviso("Debes seleccionar un proceso.");
            return false;
        }

        if (string.IsNullOrWhiteSpace(formulario.Nombre))
        {
            MostrarAviso("El nombre es obligatorio.");
            return false;
        }

        return true;
    }

    private bool ValidarEntidad<TItem>(TItem item) where TItem : class
    {
        switch (item)
        {
            case TipologiaIncidencia tipologia:
                if (string.IsNullOrWhiteSpace(tipologia.Nombre))
                {
                    MostrarAviso("El nombre es obligatorio.");
                    return false;
                }

                if (tipologia.ProcesoId <= 0)
                {
                    MostrarAviso("Debes seleccionar un proceso.");
                    return false;
                }

                return true;
            case EstadoIncidencia estadoIncidencia:
                return ValidarNombreOrden(estadoIncidencia.Nombre, estadoIncidencia.Orden);
            case EstadoDetalleIncidencia estadoDetalle:
                return ValidarNombreOrden(estadoDetalle.Nombre, estadoDetalle.Orden);
            case EstadoAccionMejora estadoAccion:
                return ValidarNombreOrden(estadoAccion.Nombre, estadoAccion.Orden);
            case EstadoProyecto estadoProyectoItem:
                return ValidarNombreOrden(estadoProyectoItem.Nombre, estadoProyectoItem.Orden);
            case PrioridadProyecto prioridad:
                return ValidarNombreOrden(prioridad.Nombre, prioridad.Orden);
            case EstadoFaseProyecto estadoFase:
                return ValidarNombreOrden(estadoFase.Nombre, estadoFase.Orden);
            default:
                var nombre = typeof(TItem).GetProperty("Nombre")?.GetValue(item)?.ToString();
                if (!string.IsNullOrWhiteSpace(nombre))
                {
                    return true;
                }

                MostrarAviso("El nombre es obligatorio.");
                return false;
        }
    }

    private bool ValidarNombreOrden(string? nombre, int orden)
    {
        if (string.IsNullOrWhiteSpace(nombre))
        {
            MostrarAviso("El nombre es obligatorio.");
            return false;
        }

        if (orden <= 0)
        {
            MostrarAviso("El orden debe ser mayor que cero.");
            return false;
        }

        return true;
    }

    private static void AplicarFormularioSimple<TItem>(TItem entidad, CatalogoSimpleFormModel formulario) where TItem : class
    {
        typeof(TItem).GetProperty("Nombre")?.SetValue(entidad, formulario.Nombre.Trim());
        typeof(TItem).GetProperty("Orden")?.SetValue(entidad, formulario.Orden);
        typeof(TItem).GetProperty("EsCierre")?.SetValue(entidad, formulario.EsCierre);
    }

    private static void CopiarValores<TItem>(TItem origen, TItem destino) where TItem : class
    {
        switch (origen)
        {
            case Departamento x when destino is Departamento y:
                y.Nombre = x.Nombre.Trim();
                break;
            case Proceso x when destino is Proceso y:
                y.Nombre = x.Nombre.Trim();
                break;
            case TipologiaIncidencia x when destino is TipologiaIncidencia y:
                y.Nombre = x.Nombre.Trim();
                y.ProcesoId = x.ProcesoId;
                y.Activa = x.Activa;
                break;
            case EstadoIncidencia x when destino is EstadoIncidencia y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                y.EsCierre = x.EsCierre;
                break;
            case EstadoDetalleIncidencia x when destino is EstadoDetalleIncidencia y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                break;
            case TipoDocumentoReferencia x when destino is TipoDocumentoReferencia y:
                y.Nombre = x.Nombre.Trim();
                break;
            case TipoAdjunto x when destino is TipoAdjunto y:
                y.Nombre = x.Nombre.Trim();
                break;
            case TipoCosteNoCalidad x when destino is TipoCosteNoCalidad y:
                y.Nombre = x.Nombre.Trim();
                break;
            case OrigenAccionMejora x when destino is OrigenAccionMejora y:
                y.Nombre = x.Nombre.Trim();
                break;
            case TipoAccionMejora x when destino is TipoAccionMejora y:
                y.Nombre = x.Nombre.Trim();
                break;
            case EstadoAccionMejora x when destino is EstadoAccionMejora y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                y.EsCierre = x.EsCierre;
                break;
            case AreaProyecto x when destino is AreaProyecto y:
                y.Nombre = x.Nombre.Trim();
                break;
            case EstadoProyecto x when destino is EstadoProyecto y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                y.EsCierre = x.EsCierre;
                break;
            case PrioridadProyecto x when destino is PrioridadProyecto y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                break;
            case EstadoFaseProyecto x when destino is EstadoFaseProyecto y:
                y.Nombre = x.Nombre.Trim();
                y.Orden = x.Orden;
                y.EsCierre = x.EsCierre;
                break;
        }
    }

    private static int GetId<TItem>(TItem item) where TItem : class
        => (int)(typeof(TItem).GetProperty("Id")?.GetValue(item) ?? 0);

    private void MostrarAviso(string mensaje)
    {
        NotificationService.Notify(NotificationSeverity.Warning, "Revision requerida", mensaje);
    }
