@page "/acciones-mejoras"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Traza.Web.Components.Dialogs
@using Traza.Web.Data
@using Traza.Web.Data.Entidades
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Acciones de Mejoras | Traza</PageTitle>

@if (cargando)
{
    <div class="card card-round">
        <div class="card-body py-5 text-center">
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
            <div class="mt-3 text-muted">Cargando acciones de mejora...</div>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div class="page-header-content">
            <h4 class="page-title">Acciones de Mejoras</h4>
            <div class="text-muted">Consulta y acceso al detalle completo de las acciones.</div>
        </div>
        <div class="page-header-actions">
            <button type="button" class="btn btn-primary btn-round" @onclick="AbrirNuevoAsync">
                <i class="fi fi-rr-plus me-2"></i>
                Nueva accion
            </button>
        </div>
    </div>

    <div class="card card-round">
        <div class="card-body">
            <RadzenDataGrid Data="@acciones" TItem="AccionMejora" AllowPaging="true" PageSize="10" EmptyText="No hay acciones de mejora registradas.">
                <Columns>
                    <RadzenDataGridColumn TItem="AccionMejora" Property="FechaCreacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="120px" />
                    <RadzenDataGridColumn TItem="AccionMejora" Title="Origen">
                        <Template Context="item">@(item.Origen?.Nombre ?? "-")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AccionMejora" Title="Tipo">
                        <Template Context="item">@(item.TipoAccion?.Nombre ?? "-")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AccionMejora" Property="Descripcion" Title="Descripcion" />
                    <RadzenDataGridColumn TItem="AccionMejora" Title="Estado">
                        <Template Context="item">@item.Estado.Nombre</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AccionMejora" Title="Acciones" Width="150px" TextAlign="TextAlign.Center">
                        <Template Context="item">
                            <button type="button" class="btn traza-icon-btn" @onclick="() => AbrirDetalleAsync(item, false)" title="Ver">
                                <i class="fi fi-rr-eye"></i>
                            </button>
                            <button type="button" class="btn traza-icon-btn" @onclick="() => AbrirDetalleAsync(item, true)" title="Editar">
                                <i class="fi fi-rr-pencil"></i>
                            </button>
                            <button type="button" class="btn traza-icon-btn traza-icon-btn-danger" @onclick="() => EliminarAsync(item.Id)" title="Eliminar">
                                <i class="fi fi-rr-trash"></i>
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private bool cargando = true;
    private List<AccionMejora> acciones = [];

    protected override async Task OnInitializedAsync()
    {
        await RecargarAsync();
        cargando = false;
    }

    private async Task RecargarAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        acciones = await db.AccionesMejora
            .AsNoTracking()
            .Include(x => x.Origen)
            .Include(x => x.TipoAccion)
            .Include(x => x.Estado)
            .OrderByDescending(x => x.FechaCreacion)
            .ToListAsync();
    }

    private async Task AbrirDetalleAsync(AccionMejora accion, bool modoEdicion)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        var detalle = await db.AccionesMejora
            .AsNoTracking()
            .Include(x => x.Solicitante)
            .Include(x => x.Coordinador)
            .Include(x => x.Estado)
            .Include(x => x.Origen)
            .Include(x => x.TipoAccion)
            .Include(x => x.Tareas).ThenInclude(x => x.UsuarioAsignado)
            .Include(x => x.Comentarios).ThenInclude(x => x.Usuario)
            .Include(x => x.Documentos).ThenInclude(x => x.TipoAdjunto)
            .Include(x => x.AccionesHijas).ThenInclude(x => x.Estado)
            .FirstAsync(x => x.Id == accion.Id);

        await DialogService.OpenAsync<AccionMejoraDetalleDialog>(
            modoEdicion ? "Editar accion de mejora" : "Ver accion de mejora",
            new Dictionary<string, object?> { [nameof(AccionMejoraDetalleDialog.Accion)] = detalle },
            new DialogOptions { Width = "1100px", Height = "760px", CloseDialogOnOverlayClick = true });
    }

    private async Task EliminarAsync(int id)
    {
        var confirmacion = await DialogService.Confirm("La accion de mejora se eliminara junto con sus datos hijos.", "Eliminar accion de mejora", new ConfirmOptions
        {
            OkButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (confirmacion != true)
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        var entidad = await db.AccionesMejora.FindAsync(id);
        if (entidad is null)
        {
            return;
        }

        db.Remove(entidad);
        try
        {
            await db.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Eliminado", "Accion de mejora eliminada correctamente.");
        }
        catch (DbUpdateException)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No se pudo eliminar", "La accion de mejora tiene relaciones que impiden su borrado.");
        }

        await RecargarAsync();
    }

    private async Task AbrirNuevoAsync()
    {
        var creado = await DialogService.OpenAsync<AccionMejoraCreacionDialog>(
            "Nueva accion de mejora",
            options: new DialogOptions { Width = "1180px", Height = "860px", CloseDialogOnOverlayClick = true });

        if (creado == true)
        {
            await RecargarAsync();
        }
    }
}
