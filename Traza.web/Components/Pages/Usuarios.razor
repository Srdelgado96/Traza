@page "/usuarios"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Traza.Web.Components.Dialogs
@using Traza.Web.Components.Models
@using Traza.Web.Data
@using Traza.Web.Data.Entidades
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Usuarios | Traza</PageTitle>

@if (cargando)
{
    <div class="card card-round">
        <div class="card-body py-5 text-center">
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
            <div class="mt-3 text-muted">Cargando usuarios...</div>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div class="page-header-content">
            <h4 class="page-title">Usuarios</h4>
            <div class="text-muted">Vista general de usuarios internos con acceso a consulta, edicion y eliminacion.</div>
        </div>
    </div>

    <div class="card card-round">
        <div class="card-body">
            <RadzenDataGrid Data="@usuarios" TItem="Usuario" AllowPaging="true" PageSize="10" EmptyText="No hay usuarios registrados.">
                <Columns>
                    <RadzenDataGridColumn TItem="Usuario" Property="Login" Title="Login" Width="140px" />
                    <RadzenDataGridColumn TItem="Usuario" Property="Nombre" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Usuario" Property="Email" Title="Email" />
                    <RadzenDataGridColumn TItem="Usuario" Title="Roles">
                        <Template Context="item">@ObtenerRolesTexto(item)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Usuario" Title="Departamento">
                        <Template Context="item">@(item.Departamento?.Nombre ?? "-")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Usuario" Title="Supervisor">
                        <Template Context="item">@(item.Supervisor?.Nombre ?? "-")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Usuario" Title="Activo" Width="110px">
                        <Template Context="item">@(item.Activo ? "Si" : "No")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Usuario" Title="Acciones" Width="160px" TextAlign="TextAlign.Center">
                        <Template Context="item">
                            <button type="button" class="btn traza-icon-btn" @onclick="() => AbrirDetalleAsync(item.Id)" title="Ver">
                                <i class="fi fi-rr-eye"></i>
                            </button>
                            <button type="button" class="btn traza-icon-btn" @onclick="() => AbrirEdicionAsync(item.Id)" title="Editar">
                                <i class="fi fi-rr-pencil"></i>
                            </button>
                            <button type="button" class="btn traza-icon-btn traza-icon-btn-danger" @onclick="() => EliminarAsync(item.Id)" title="Eliminar">
                                <i class="fi fi-rr-trash"></i>
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private bool cargando = true;
    private List<Usuario> usuarios = [];

    protected override async Task OnInitializedAsync()
    {
        await RecargarAsync();
        cargando = false;
    }

    private async Task RecargarAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        usuarios = await db.Usuarios
            .AsNoTracking()
            .Include(x => x.Departamento)
            .Include(x => x.Supervisor)
            .Include(x => x.RolesAsignados).ThenInclude(x => x.Rol)
            .OrderBy(x => x.Nombre)
            .ToListAsync();
    }

    private async Task AbrirDetalleAsync(int id)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        var usuario = await db.Usuarios
            .AsNoTracking()
            .Include(x => x.Departamento)
            .Include(x => x.Supervisor)
            .Include(x => x.RolesAsignados).ThenInclude(x => x.Rol)
            .FirstAsync(x => x.Id == id);

        var numeroColaboradores = await db.Usuarios.CountAsync(x => x.SupervisorId == id);
        var incidenciasDetectadas = await db.Incidencias.CountAsync(x => x.DetectorId == id);
        var incidenciasCoordinadas = await db.Incidencias.CountAsync(x => x.CoordinadorId == id);
        var accionesSolicitadas = await db.AccionesMejora.CountAsync(x => x.SolicitanteId == id);
        var proyectosCoordinados = await db.Proyectos.CountAsync(x => x.CoordinadorId == id);

        await DialogService.OpenAsync<UsuarioDetalleDialog>(
            "Ficha de usuario",
            new Dictionary<string, object?>
            {
                [nameof(UsuarioDetalleDialog.Usuario)] = usuario,
                [nameof(UsuarioDetalleDialog.NumeroColaboradores)] = numeroColaboradores,
                [nameof(UsuarioDetalleDialog.IncidenciasDetectadas)] = incidenciasDetectadas,
                [nameof(UsuarioDetalleDialog.IncidenciasCoordinadas)] = incidenciasCoordinadas,
                [nameof(UsuarioDetalleDialog.AccionesSolicitadas)] = accionesSolicitadas,
                [nameof(UsuarioDetalleDialog.ProyectosCoordinados)] = proyectosCoordinados,
                [nameof(UsuarioDetalleDialog.Roles)] = usuario.RolesAsignados.Select(x => x.Rol.Nombre).OrderBy(x => x).ToList()
            },
            new DialogOptions { Width = "900px", Height = "620px", CloseDialogOnOverlayClick = true });
    }

    private async Task AbrirEdicionAsync(int id)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        var usuario = await db.Usuarios.AsNoTracking().FirstAsync(x => x.Id == id);
        var departamentos = await db.Departamentos.AsNoTracking().OrderBy(x => x.Nombre).ToListAsync();
        var supervisores = await db.Usuarios.AsNoTracking().Where(x => x.Id != id).OrderBy(x => x.Nombre).ToListAsync();
        var roles = await db.Roles.AsNoTracking().Where(x => x.Activo).OrderBy(x => x.Nombre).ToListAsync();
        var rolesSeleccionados = await db.UsuariosRol.AsNoTracking().Where(x => x.UsuarioId == id).Select(x => x.RolId).ToListAsync();

        var editable = new UsuarioEdicionFormModel
        {
            Id = usuario.Id,
            Login = usuario.Login,
            Nombre = usuario.Nombre,
            Email = usuario.Email,
            Genero = usuario.Genero,
            SupervisorId = usuario.SupervisorId,
            DepartamentoId = usuario.DepartamentoId,
            Activo = usuario.Activo,
            RolesSeleccionados = rolesSeleccionados
        };

        var resultado = await DialogService.OpenAsync<UsuarioEdicionDialog>(
            "Editar usuario",
            new Dictionary<string, object?>
            {
                [nameof(UsuarioEdicionDialog.Modelo)] = editable,
                [nameof(UsuarioEdicionDialog.Departamentos)] = departamentos,
                [nameof(UsuarioEdicionDialog.Supervisores)] = supervisores,
                [nameof(UsuarioEdicionDialog.Roles)] = roles
            },
            new DialogOptions { Width = "920px", Height = "700px", CloseDialogOnOverlayClick = true });

        if (resultado is not UsuarioEdicionFormModel editado)
        {
            return;
        }

        if (!ValidarUsuario(editado))
        {
            return;
        }

        await using var dbGuardar = await DbContextFactory.CreateDbContextAsync();
        var entidad = await dbGuardar.Usuarios.FindAsync(id);
        if (entidad is null)
        {
            return;
        }

        entidad.Login = editado.Login.Trim();
        entidad.Nombre = editado.Nombre.Trim();
        entidad.Email = string.IsNullOrWhiteSpace(editado.Email) ? null : editado.Email.Trim();
        entidad.Genero = string.IsNullOrWhiteSpace(editado.Genero) ? null : editado.Genero.Trim();
        entidad.DepartamentoId = editado.DepartamentoId;
        entidad.SupervisorId = editado.SupervisorId;
        entidad.Activo = editado.Activo;
        var rolesActuales = await dbGuardar.UsuariosRol.Where(x => x.UsuarioId == id).ToListAsync();
        dbGuardar.UsuariosRol.RemoveRange(rolesActuales);
        foreach (var rolId in editado.RolesSeleccionados.Distinct())
        {
            dbGuardar.UsuariosRol.Add(new UsuarioRol { UsuarioId = id, RolId = rolId });
        }

        try
        {
            await dbGuardar.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Guardado", "Usuario actualizado correctamente.");
            await RecargarAsync();
        }
        catch (DbUpdateException)
        {
            NotificationService.Notify(NotificationSeverity.Error, "No se pudo guardar", "Revisa si el login ya existe o si hay datos obligatorios vacios.");
        }
    }

    private async Task EliminarAsync(int id)
    {
        var confirmacion = await DialogService.Confirm("El usuario se eliminara si no tiene relaciones activas con incidencias, acciones o proyectos.", "Eliminar usuario", new ConfirmOptions
        {
            OkButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (confirmacion != true)
        {
            return;
        }

        await using var db = await DbContextFactory.CreateDbContextAsync();
        var entidad = await db.Usuarios.FindAsync(id);
        if (entidad is null)
        {
            return;
        }

        db.Remove(entidad);

        try
        {
            await db.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Eliminado", "Usuario eliminado correctamente.");
            await RecargarAsync();
        }
        catch (DbUpdateException)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No se pudo eliminar", "Este usuario esta relacionado con otros datos y no se puede borrar.");
        }
    }

    private bool ValidarUsuario(Usuario usuario)
    {
        return ValidarUsuario(new UsuarioEdicionFormModel
        {
            Id = usuario.Id,
            Login = usuario.Login,
            Nombre = usuario.Nombre,
            SupervisorId = usuario.SupervisorId
        });
    }

    private bool ValidarUsuario(UsuarioEdicionFormModel usuario)
    {
        if (string.IsNullOrWhiteSpace(usuario.Login))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Revision requerida", "El login es obligatorio.");
            return false;
        }

        if (string.IsNullOrWhiteSpace(usuario.Nombre))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Revision requerida", "El nombre es obligatorio.");
            return false;
        }

        if (usuario.SupervisorId == usuario.Id)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Revision requerida", "Un usuario no puede ser su propio supervisor.");
            return false;
        }

        return true;
    }

    private static string ObtenerRolesTexto(Usuario usuario)
    {
        var roles = usuario.RolesAsignados
            .Select(x => x.Rol.Nombre)
            .OrderBy(x => x)
            .ToList();

        return roles.Count == 0 ? "-" : string.Join(", ", roles);
    }
}
